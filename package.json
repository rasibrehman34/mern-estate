{
  "name": "mern-estate",
  "version": "1.0.0",
  "description": "MERN real estate application",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "node api/server.js",
    "preview": "npm run preview --prefix client",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [],
