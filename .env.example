# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGO=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Auth
JWT_SECRET=your_jwt_secret_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (CORS — set to your Vercel production URL)
CLIENT_URL=http://localhost:5173

# Vite (client) — only VITE_* vars are exposed to the browser
VITE_FIREBASE_API_KEY=
VITE_API_URL=
VITE_DEV_API_URL=http://localhost:3000
